# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI — OpenRouter (recommended: free + paid models via one key)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
# Free model for dev/MVP (change when you need better quality):
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
# Other good options:
# OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
# OPENROUTER_MODEL=openai/gpt-4o-mini

# AI — Direct OpenAI (optional fallback if you prefer)
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# Email (Resend)
RESEND_API_KEY=re_your-resend-key
RESEND_FROM_EMAIL=Bookings <bookings@yourdomain.com>

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Automation (n8n)
N8N_WEBHOOK_URL=https://your-n8n-instance.app/webhook/appointment
N8N_WEBHOOK_SECRET=your-webhook-secret

# Demo
NEXT_PUBLIC_DEMO_BUSINESS_ID=your-demo-business-uuid

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
